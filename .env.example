# TouchMorph Configuration
TOUCHMORPH_HOST=0.0.0.0
TOUCHMORPH_PORT=3000

# SMTP Email (for sending tunnel URL)
# Use any email provider (Gmail, Outlook, etc.)
# For Gmail: enable App Passwords at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your.email@gmail.com
EMAIL_TO=recipient@example.com

# Admin Dashboard (optional — leave blank to keep dashboard open)
# Setting ADMIN_PASSWORD protects /admin, /api/devices, /api/kick with a login page
ADMIN_PASSWORD=
ADMIN_SECRET=touchmorph-dev-secret-change-me
