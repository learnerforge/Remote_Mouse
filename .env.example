# SMTP Configuration for sending tunnel URL to your phone
# Gmail example (use App Password, not your regular password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your.email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your.email@gmail.com
# SMTP_TO_EMAIL=your-phone-number@vtext.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAIL=
